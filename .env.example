# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase (safe to expose — these are anon/public keys, protected by RLS)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Sign-In — the "Web" OAuth client ID from Google Cloud Console
# (Supabase's Google provider must use this SAME web client id + secret).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Sentry crash reporting — the DSN from your Sentry project (Settings → Client Keys).
# Safe to expose (it's a write-only ingest key). Leave unset to disable Sentry.
EXPO_PUBLIC_SENTRY_DSN=https://xxxx@oyyyy.ingest.sentry.io/zzzz
