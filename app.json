{
  "expo": {
    "name": "Ritham",
    "slug": "ritham",
    "version": "1.0.0",
    "scheme": "ritham",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D0D1A",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ritham.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Ritham needs your microphone so you can talk with your AI astrologer on a voice call."
      }
    },
    "androidStatusBar": {
      "translucent": true,
      "barStyle": "light-content",
      "backgroundColor": "#00000000"
    },
    "androidNavigationBar": {
      "barStyle": "light-content",
      "backgroundColor": "#00000000"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0D1A",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.ritham.app",
      "permissions": ["RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0D1A",
          "resizeMode": "contain",
          "image": "./assets/splash-icon.png",
          "imageWidth": 220
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ritham needs access to your photos so you can upload your floor plan for the Vaastu report."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF007F"
        }
      ],
      "@react-native-google-signin/google-signin",
      "@daily-co/config-plugin-rn-daily-js",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": ["https://www.jitpack.io"]
          }
        }
      ],
      "./plugins/withDailyWebrtcFix"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
